---
interface Props {
  title?: string;
}
const { title = "Onur Adıgüzel — Game Programmer" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content="Onur Adıgüzel (KiiVoZin) — Game Programmer based in Warsaw. Specializing in gameplay systems, shaders, and optimization across Unreal Engine 5, Unity, and Godot." />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&family=Share+Tech+Mono&display=swap" rel="stylesheet" />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --green:       #3fb950;
    --green-dim:   #238636;
    --green-dark:  #0f2d0f;
    --green-faint: #091409;
    --bg:          #020302;
    --bg-card:     #070c07;
    --text:        #c9d1d9;
    --text-dim:    #8b949e;
    --border:      #1e2e1e;
    --font-pixel:  'Press Start 2P', monospace;
    --font-mono:   'Share Tech Mono', monospace;
  }

  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html { scroll-behavior: smooth; }

  body {
    background-color: var(--bg);
    color: var(--text);
    font-family: var(--font-mono);
    font-size: 1rem;
    line-height: 1.7;
    min-height: 100vh;
  }

  h1, h2, h3 {
    font-family: var(--font-pixel);
    color: var(--green);
    line-height: 1.5;
  }

  a {
    color: var(--green);
    text-decoration: none;
  }

  a:hover { text-decoration: underline; }

  section {
    padding: 5rem 1.5rem;
    max-width: 900px;
    margin: 0 auto;
  }

  .section-title {
    font-family: var(--font-pixel);
    font-size: 0.75rem;
    color: var(--green);
    margin-bottom: 2.5rem;
  }

  .section-title::before {
    content: '> ';
    color: var(--green-dim);
  }

  .section-title::after {
    content: ' _';
    animation: blink 1s step-end infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }
</style>
