---
const education = [
  {
    degree: "Video Game Programming",
    school: "Futuregames Warsaw",
    location: "Warsaw, Poland",
    period: "2024 — present",
    description: "Specialized program in game programming across engines, disciplines, and real team projects.",
    current: true,
  },
  {
    degree: "Bachelor's in Computer Science",
    school: "TOBB University of Economics and Technology",
    location: "Ankara, Turkey",
    period: "2019 — 2023",
    description: "Computer science fundamentals. Where it all started.",
    current: false,
  },
];
---

<section id="education">
  <div class="timeline">
    {education.map((entry) => (
      <div class="entry">
        <div class="entry-left">
          <span class="entry-period">{entry.period}</span>
          {entry.current && <span class="badge">CURRENT</span>}
        </div>
        <div class="entry-line">
          <div class="entry-dot"></div>
          <div class="entry-track"></div>
        </div>
        <div class="entry-right">
          <h3 class="entry-degree">{entry.degree}</h3>
          <p class="entry-school">{entry.school} — <span class="entry-location">{entry.location}</span></p>
          <p class="entry-desc">{entry.description}</p>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .timeline {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .entry {
    display: grid;
    grid-template-columns: 130px 24px 1fr;
    gap: 0 1rem;
    align-items: start;
  }

  .entry-left {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.4rem;
    padding-top: 0.15rem;
  }

  .entry-period {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-dim);
    text-align: right;
  }

  .badge {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--green);
    background: var(--green-dark);
    border: 1px solid var(--green-dim);
    padding: 0.1rem 0.4rem;
    border-radius: 2px;
  }

  .entry-line {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
  }

  .entry-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--green);
    border: 2px solid var(--bg);
    outline: 1px solid var(--green-dim);
    margin-top: 0.2rem;
    flex-shrink: 0;
  }

  .entry-track {
    flex: 1;
    width: 1px;
    background: var(--border);
    min-height: 60px;
  }

  .entry-right {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding-bottom: 0.5rem;
  }

  .entry-degree {
    font-family: var(--font-pixel);
    font-size: 0.55rem;
    color: var(--green);
    line-height: 1.8;
  }

  .entry-school {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--text);
  }

  .entry-location {
    color: var(--text-dim);
  }

  .entry-desc {
    font-family: var(--font-mono);
    font-size: 0.88rem;
    color: var(--text-dim);
    line-height: 1.7;
  }

  @media (max-width: 500px) {
    .entry {
      grid-template-columns: 90px 20px 1fr;
    }
    .entry-period {
      font-size: 0.7rem;
    }
  }
</style>
