---
const links = [
  { label: "github", handle: "@yourusername", href: "https://github.com/yourusername" },
  { label: "itch.io", handle: "yourusername.itch.io", href: "https://yourusername.itch.io" },
  { label: "email", handle: "you@email.com", href: "mailto:you@email.com" },
  { label: "twitter", handle: "@yourusername", href: "https://twitter.com/yourusername" },
];
---

<section id="contact">
  <h2 class="section-title">contact</h2>
  <p class="intro">Want to collaborate, hire me, or just say hi? Reach out through any of these.</p>
  <div class="links">
    {links.map((l) => (
      <a href={l.href} class="link-row" target="_blank" rel="noopener noreferrer">
        <span class="link-label">{l.label}</span>
        <span class="link-separator"> ──────── </span>
        <span class="link-handle">{l.handle}</span>
        <span class="link-arrow"> ›</span>
      </a>
    ))}
  </div>
  <p class="footer">
    Built with <a href="https://astro.build" target="_blank">Astro</a>. Deployed on GitHub Pages.
  </p>
</section>

<style>
  .intro {
    font-family: var(--font-mono);
    font-size: 0.95rem;
    color: var(--text-dim);
    margin-bottom: 2rem;
  }

  .links {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 4rem;
  }

  .link-row {
    display: flex;
    align-items: baseline;
    gap: 0;
    font-family: var(--font-mono);
    font-size: 1rem;
    color: var(--text);
    text-decoration: none;
    padding: 0.6rem 1rem;
    border: 1px solid var(--border);
    border-radius: 3px;
    background: var(--bg-card);
    transition: border-color 0.2s, background 0.2s;
  }

  .link-row:hover {
    border-color: var(--green-dim);
    background: var(--green-faint);
    text-decoration: none;
    color: var(--text);
  }

  .link-label {
    color: var(--green);
    min-width: 80px;
  }

  .link-separator {
    color: var(--border);
    flex: 1;
    overflow: hidden;
    white-space: nowrap;
    letter-spacing: 0.05em;
  }

  .link-handle {
    color: var(--text-dim);
  }

  .link-arrow {
    color: var(--green-dim);
    margin-left: 0.5rem;
    transition: color 0.2s;
  }

  .link-row:hover .link-arrow {
    color: var(--green);
  }

  .footer {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-dim);
    text-align: center;
    padding-bottom: 2rem;
  }

  .footer a {
    color: var(--green-dim);
  }

  .footer a:hover {
    color: var(--green);
  }
</style>
