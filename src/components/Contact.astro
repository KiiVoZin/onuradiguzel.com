---
const links = [
  {
    label: "email",
    handle: "onur.adiguzel@hotmail.com",
    href: "mailto:onur.adiguzel@hotmail.com",
  },
  {
    label: "linkedin",
    handle: "Onur Adıgüzel",
    href: "https://www.linkedin.com/in/onur-a-61383a20a/",
  },
  {
    label: "github",
    handle: "KiiVoZin",
    href: "https://github.com/KiiVoZin",
  },
  {
    label: "steam",
    handle: "KiiVoZin",
    href: "https://steamcommunity.com/id/KiiVoZin/",
  },
];
---

<section id="contact">
  <p class="intro">Want to work together, have a project in mind, or just want to talk games?<br />I'm always open to a conversation.</p>
  <div class="links">
    {links.map((l) => (
      <a href={l.href} class="link-row" target={l.href.startsWith('mailto') ? '_self' : '_blank'} rel="noopener noreferrer">
        <span class="link-label">{l.label}</span>
        <span class="link-sep"> ──── </span>
        <span class="link-handle">{l.handle}</span>
        <span class="link-arrow"> ›</span>
      </a>
    ))}
  </div>
</section>

<style>
  .intro {
    font-family: var(--font-mono);
    font-size: 0.95rem;
    color: var(--text-dim);
    margin-bottom: 2rem;
    line-height: 1.8;
  }

  .links {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .link-row {
    display: flex;
    align-items: baseline;
    font-family: var(--font-mono);
    font-size: 1rem;
    color: var(--text);
    text-decoration: none;
    padding: 0.7rem 1rem;
    border: 1px solid var(--border);
    border-radius: 3px;
    background: var(--bg-card);
    transition: border-color 0.2s, background 0.2s;
  }

  .link-row:hover {
    border-color: var(--green-dim);
    background: var(--green-faint);
    text-decoration: none;
    color: var(--text);
  }

  .link-label {
    color: var(--green);
    min-width: 80px;
  }

  .link-sep {
    color: var(--border);
    margin: 0 0.3rem;
  }

  .link-handle {
    color: var(--text-dim);
    flex: 1;
  }

  .link-arrow {
    color: var(--green-dim);
    margin-left: 0.5rem;
    transition: color 0.2s;
  }

  .link-row:hover .link-arrow {
    color: var(--green);
  }

  .footer {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-dim);
    text-align: center;
    padding-bottom: 2rem;
  }

  .footer a {
    color: var(--green-dim);
  }

  .footer a:hover {
    color: var(--green);
  }
</style>
