---
---

<section class="hero" id="hero">
  <div id="hero-terminal">
    <div class="terminal-bar">
      <span class="terminal-title">portfolio.exe</span>
      <div class="terminal-btns">
        <span class="tbtn">−</span>
        <span class="tbtn">□</span>
        <span class="tbtn">×</span>
      </div>
    </div>
    <div class="terminal-body" id="terminal-body"></div>
  </div>
  <div class="scroll-hint" id="scroll-hint">scroll down ↓</div>
</section>

<script>
  const body = document.getElementById('terminal-body');
  const hint = document.getElementById('scroll-hint');

  const script = [
    { kind: 'command', text: 'whoami' },
    { kind: 'output',  text: 'Onur Adıgüzel',  classes: ['name'] },
    { kind: 'output',  text: '// aka KiiVoZin', classes: ['alias'] },
    { kind: 'command', text: 'title' },
    { kind: 'output',  text: 'Game Programmer' },
    { kind: 'command', text: 'tagline' },
    { kind: 'output',  text: 'I write the code that makes worlds feel alive.', classes: ['dim'] },
  ];

  const CMD_DELAY = 70;
  const OUT_DELAY = 18;
  const PRE_CMD   = 500;
  const POST_CMD  = 150;

  const sleep = ms => new Promise(r => setTimeout(r, ms));

  function flash() {
    body.style.borderColor = 'var(--green-dim)';
    body.style.boxShadow   = '0 0 12px rgba(63,185,80,0.15)';
    setTimeout(() => {
      body.style.borderColor = '';
      body.style.boxShadow   = '';
    }, 90);
  }

  async function typeInto(el, text, delay) {
    for (const char of text) {
      el.textContent += char;
      flash();
      const jitter = delay === CMD_DELAY ? (Math.random() * 40 - 20) : 0;
      await sleep(delay + jitter);
    }
  }

  function addPromptLine() {
    const p = document.createElement('p');
    p.className = 'line';
    const s = document.createElement('span');
    s.className = 'prompt';
    s.textContent = '$ ';
    p.appendChild(s);
    body.appendChild(p);
    return p;
  }

  function showInstant() {
    for (const entry of script) {
      if (entry.kind === 'command') {
        const p = addPromptLine();
        const span = document.createElement('span');
        span.className = 'cmd-text';
        span.textContent = entry.text;
        p.appendChild(span);
      } else {
        const p = document.createElement('p');
        p.className = ['line', 'output', ...(entry.classes ?? [])].join(' ');
        p.textContent = entry.text;
        body.appendChild(p);
      }
    }
    const p = addPromptLine();
    const cursor = document.createElement('span');
    cursor.className = 'typing-cursor';
    cursor.textContent = '█';
    p.appendChild(cursor);
    hint.classList.add('visible');
  }

  async function runAnimated() {
    for (const entry of script) {
      if (entry.kind === 'command') {
        await sleep(PRE_CMD);
        const p = addPromptLine();
        const span = document.createElement('span');
        span.className = 'cmd-text';
        p.appendChild(span);
        await typeInto(span, entry.text, CMD_DELAY);
        await sleep(POST_CMD);
      } else {
        const p = document.createElement('p');
        p.className = ['line', 'output', ...(entry.classes ?? [])].join(' ');
        body.appendChild(p);
        await typeInto(p, entry.text, OUT_DELAY);
        await sleep(80);
      }
      body.scrollTop = body.scrollHeight;
    }
    const p = addPromptLine();
    const cursor = document.createElement('span');
    cursor.className = 'typing-cursor';
    cursor.textContent = '█';
    p.appendChild(cursor);
    hint.classList.add('visible');
    localStorage.setItem('visited', '1');
  }

  if (localStorage.getItem('visited')) {
    showInstant();
  } else {
    runAnimated();
  }
</script>

<style is:global>
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 6rem 1.5rem 3rem;
    max-width: 900px;
    margin: 0 auto;
  }

  .terminal-bar {
    background: var(--green-dark);
    border: 1px solid var(--border);
    border-bottom: none;
    border-radius: 6px 6px 0 0;
    padding: 0.5rem 1rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .terminal-title {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-dim);
  }

  .terminal-btns {
    display: flex;
    gap: 0.4rem;
  }

  .tbtn {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: rgba(63, 185, 80, 0.5);
    border: 1px solid rgba(63, 185, 80, 0.25);
    padding: 0.05rem 0.4rem;
    border-radius: 2px;
    cursor: default;
    user-select: none;
    line-height: 1.4;
    transition: border-color 0.15s, color 0.15s;
  }

  .tbtn:hover {
    border-color: var(--green-dim);
    color: var(--green);
  }

  .cmd-text { color: #e3b341; }

  .terminal-body {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 0 0 6px 6px;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    min-height: 220px;
    transition: border-color 0.1s ease, box-shadow 0.1s ease;
  }

  .line {
    font-family: var(--font-mono);
    font-size: 1.05rem;
    color: var(--text);
    min-height: 1.5em;
  }

  .prompt { color: var(--green); font-weight: bold; }

  .output        { padding-left: 1.4rem; color: var(--text); }
  .output.name   { font-family: var(--font-pixel); font-size: 1rem; color: var(--green); line-height: 1.8; }
  .output.alias  { font-family: var(--font-mono); font-size: 0.85rem; color: var(--text-dim); margin-bottom: 0.3rem; }
  .output.dim    { color: var(--text-dim); }

  .typing-cursor { color: var(--green); animation: blink 1s step-end infinite; }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }

  .scroll-hint {
    margin-top: 2rem;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-dim);
    text-align: center;
    opacity: 0;
    transition: opacity 0.8s ease;
  }

  .scroll-hint.visible {
    opacity: 1;
    animation: fade 2s ease-in-out infinite;
  }

  @keyframes fade {
    0%, 100% { opacity: 0.3; }
    50%       { opacity: 1; }
  }

  @media (max-width: 480px) {
    .output.name { font-size: 0.65rem; }
    .line        { font-size: 0.9rem; }
  }
</style>
