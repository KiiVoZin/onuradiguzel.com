---
import { projects } from '../data/projects.js';

const tagColor = {
  'UE5':                { color: '#79c0ff', border: '#1f4473', bg: '#0d1f33' },
  'Unity':              { color: '#d2a8ff', border: '#3d2063', bg: '#1a0d2e' },
  'C#':                 { color: '#56d364', border: '#1a4a1e', bg: '#0d2010' },
  'C++':                { color: '#e3b341', border: '#674e10', bg: '#2d2100' },
  'GDScript':           { color: '#4fc3f7', border: '#1a4a6b', bg: '#0d2030' },
};

const statusColor = {
  'Shipped':      { bg: 'var(--green-dark)',  text: 'var(--green)',    border: 'var(--green-dim)' },
  'WIP':          { bg: '#1a1400',            text: '#ffcc00',         border: '#665200' },
  'Internal':     { bg: '#0d0d1a',            text: '#7777ff',         border: '#333388' },
  'Professional': { bg: '#1a0d00',            text: '#ff9933',         border: '#663d00' },
};
---

<section id="projects">
  <h2 class="section-title">projects</h2>
  <div class="grid">
    {projects.map((p) => {
      const s = statusColor[p.status] ?? statusColor['Shipped'];
      return (
        <a href={`/projects/${p.slug}`} class="card">
          <div class="card-top">
            <span class="card-category">{p.category}</span>
            <span class="card-status" style={`background:${s.bg};color:${s.text};border-color:${s.border}`}>
              {p.status}
            </span>
          </div>
          <h3 class="card-name">{p.name}</h3>
          <p class="card-meta">{p.engine} · {p.year}</p>
          <p class="card-short">{p.short}</p>
          <div class="card-tags">
            {p.tags.map(t => {
              const tc = tagColor[t];
              return tc
                ? <span class="tag" style={`color:${tc.color};border-color:${tc.border};background:${tc.bg}`}>{t}</span>
                : <span class="tag">{t}</span>;
            })}
          </div>
          <span class="card-cta">read more ›</span>
        </a>
      );
    })}
  </div>
</section>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(270px, 1fr));
    gap: 1.25rem;
  }

  .card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 1.25rem;
    text-decoration: none;
    color: var(--text);
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .card:hover {
    border-color: var(--green-dim);
    box-shadow: 0 0 12px rgba(0,255,65,0.07);
    text-decoration: none;
  }

  .card-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .card-category {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-dim);
  }

  .card-status {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    padding: 0.1rem 0.45rem;
    border-radius: 2px;
    border: 1px solid;
  }

  .card-name {
    font-family: var(--font-pixel);
    font-size: 0.55rem;
    color: var(--green);
    line-height: 1.8;
    margin-top: 0.25rem;
  }

  .card-meta {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-dim);
  }

  .card-short {
    font-family: var(--font-mono);
    font-size: 0.88rem;
    color: var(--text);
    line-height: 1.6;
    flex: 1;
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-top: 0.25rem;
  }

  .tag {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-dim);
    border: 1px solid var(--border);
    padding: 0.1rem 0.4rem;
    border-radius: 2px;
  }


  .card-cta {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--green-dim);
    margin-top: 0.4rem;
    transition: color 0.2s;
  }

  .card:hover .card-cta {
    color: var(--green);
  }
</style>
