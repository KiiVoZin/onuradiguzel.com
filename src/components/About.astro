---
const skills = [
  { category: "ENGINES", items: ["Unity", "Godot", "Unreal"] },
  { category: "LANGUAGES", items: ["C#", "C++", "GDScript", "Python"] },
  { category: "TOOLS", items: ["Git", "Blender", "Aseprite"] },
];
---

<section id="about">
  <h2 class="section-title">about</h2>
  <div class="about-grid">
    <div class="bio">
      <p>
        Hi — I'm <strong>Your Name</strong>, a video game developer based in
        <strong>Your City</strong>. I've been making games since [year], driven
        by a love for interactive worlds and tight game feel.
      </p>
      <p>
        I work across the full development cycle — design, programming, and
        sometimes even art. I enjoy game jams, solo projects, and collaborating
        with small teams.
      </p>
      <p class="dim">
        When I'm not making games, I'm probably playing them.
      </p>
    </div>

    <div class="skills">
      {skills.map((group) => (
        <div class="skill-group">
          <p class="skill-category">{group.category}</p>
          <div class="skill-items">
            {group.items.map((item) => (
              <span class="skill-item">{item}</span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
  }

  .bio {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .bio p {
    font-family: var(--font-mono);
    font-size: 0.95rem;
    color: var(--text);
    line-height: 1.8;
  }

  .bio p.dim {
    color: var(--text-dim);
  }

  .bio strong {
    color: var(--green);
    font-weight: normal;
  }

  .skills {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .skill-category {
    font-family: var(--font-pixel);
    font-size: 0.5rem;
    color: var(--green-dim);
    margin-bottom: 0.5rem;
    letter-spacing: 0.1em;
  }

  .skill-items {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .skill-item {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--text);
    background: var(--bg-card);
    border: 1px solid var(--border);
    padding: 0.2rem 0.6rem;
    border-radius: 2px;
  }

  @media (max-width: 600px) {
    .about-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
