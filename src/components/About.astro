---
const skills = [
  { category: "LANGUAGES", items: ["C#", "C++", "GDScript"] },
  { category: "ENGINES", items: ["Unreal Engine", "Unity", "Godot"] },
  { category: "TOOLS", items: ["Perforce", "Git", "HLSL"] },
];

const favorites = ["Terraria", "inFAMOUS 2", "Factorio"];
---

<section id="about">
  <div class="about-grid">
    <div class="bio">
      <div class="avatar-wrap">
        <img src="/avatar.jpg" alt="Onur Adıgüzel" class="avatar" />
      </div>
      <p>
        I'm <strong>Onur Adıgüzel</strong> — a game programmer based in <strong>Warsaw</strong>,
        currently studying Video Game Programming at Futuregames.
        I've been building games since 2020 and I haven't stopped since.
      </p>
      <p>
        I'm a generalist: I'm as comfortable writing gameplay systems as I am
        debugging shaders or wiring up tools. I care deeply about game feel —
        that invisible layer of polish that separates a game from an <em>experience</em>.
      </p>
      <p>
        Outside of code, I make music — mixing, composing, producing.
        It's a different kind of system design, and it keeps my brain honest.
        You'll also find me on a tennis court, deep in a board game, or
        theorycrafting a Factorio build I'll never finish.
      </p>

    </div>

    <div class="skills">
      {skills.map((group) => (
        <div class="skill-group">
          <p class="skill-category">{group.category}</p>
          <div class="skill-items">
            {group.items.map((item) => (
              <span class="skill-item">{item}</span>
            ))}
          </div>
        </div>
      ))}
      <div class="favorites">
        <p class="fav-label">// all-time favorites</p>
        <div class="fav-list">
          {favorites.map((game, i) => (
            <span class="fav-item"><span class="fav-num">{String(i + 1).padStart(2, '0')}.</span> {game}</span>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    align-items: start;
    width: 100%;
  }

  .bio {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    overflow: hidden;
  }

  .avatar-wrap {
    width: 140px;
    height: 140px;
    border-radius: 50%;
    overflow: hidden;
    border: 2px solid var(--green-dim);
    box-shadow: 0 0 16px rgba(0, 255, 65, 0.12);
    flex-shrink: 0;
  }

  .avatar {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 45%;
  }

  .bio p {
    font-family: var(--font-mono);
    font-size: 0.95rem;
    color: var(--text);
    line-height: 1.8;
  }

  .bio strong {
    color: var(--green);
    font-weight: normal;
  }

  .bio em {
    color: var(--green-dim);
    font-style: normal;
  }

  .favorites {
    margin-top: 0.5rem;
    padding: 1rem;
    border: 1px solid var(--border);
    border-radius: 4px;
    background: var(--bg-card);
  }

  .fav-label {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-dim);
    margin-bottom: 0.6rem;
  }

  .fav-list {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .fav-item {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--text);
  }

  .fav-num {
    color: var(--green-dim);
    margin-right: 0.4rem;
  }

  .skills {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-top: calc(140px + 1rem);
  }

  .skill-category {
    font-family: var(--font-pixel);
    font-size: 0.5rem;
    color: var(--green-dim);
    margin-bottom: 0.6rem;
    letter-spacing: 0.1em;
  }

  .skill-items {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .skill-item {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--text);
    background: var(--bg-card);
    border: 1px solid var(--border);
    padding: 0.2rem 0.6rem;
    border-radius: 2px;
  }

  @media (max-width: 600px) {
    .about-grid {
      grid-template-columns: 1fr;
    }
    .skills {
      margin-top: 0;
    }
  }
</style>
